aws_region   = "us-east-1"
project_name = "vprofile"
environment  = "dev"

# Existing EC2 key-pair name in the selected Region.
key_name = "your-key-pair-name"

# Replace with your current public IPv4 address followed by /32.
admin_cidr = "203.0.113.10/32"

# Lab values used by the application. Change the passwords before deployment.
db_name     = "accounts"
db_username = "root"
db_password = "REPLACE_WITH_A_STRONG_DATABASE_PASSWORD"

mq_username = "rabbitadmin"
mq_password = "REPLACE_WITH_A_STRONG_RABBITMQ_PASSWORD"

# Optional sizing and version overrides.
# tomcat_instance_type = "t3.small"
# db_instance_class    = "db.t3.micro"
# db_engine_version    = "8.4"
# cache_node_type      = "cache.t3.micro"
# mq_instance_type     = "mq.m7g.medium"
# mq_engine_version    = "3.13"

# Lab-friendly deletion settings. Change for production.
db_multi_az            = false
db_deletion_protection = false
db_skip_final_snapshot = true

additional_tags = {
  Owner = "Aya"
}
